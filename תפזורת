<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>תפזורת פרשות חומש שמות</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f0f2f5; display: flex; flex-direction: column; align-items: center; padding: 20px; }
        h1 { color: #2c3e50; margin-bottom: 10px; }
        .container { display: flex; gap: 40px; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); flex-wrap: wrap; justify-content: center; }
        #grid { display: grid; grid-template-columns: repeat(12, 35px); gap: 5px; user-select: none; background: #ecf0f1; padding: 10px; border-radius: 8px; border: 2px solid #bdc3c7; }
        .cell { width: 35px; height: 35px; display: flex; align-items: center; justify-content: center; background: white; font-weight: bold; font-size: 1.2rem; cursor: pointer; border-radius: 4px; transition: 0.2s; }
        .cell.selected { background-color: #3498db; color: white; }
        .cell.found { background-color: #2ecc71; color: white; }
        #word-list { min-width: 150px; }
        #word-list h3 { border-bottom: 2px solid #3498db; padding-bottom: 5px; }
        ul { list-style: none; padding: 0; }
        li { padding: 5px 0; font-size: 1.1rem; color: #34495e; transition: 0.3s; }
        li.found { text-decoration: line-through; color: #bdc3c7; font-style: italic; }
        .instructions { margin-top: 20px; color: #7f8c8d; font-size: 0.9rem; }
    </style>
</head>
<body>

    <h1>תפזורת פרשות חומש שמות</h1>
    
    <div class="container">
        <div id="grid"></div>
        
        <div id="word-list">
            <h3>רשימת המילים:</h3>
            <ul id="ul-words"></ul>
        </div>
    </div>

    <div class="instructions">גררו את העכבר כדי לסמן מילים (מימין לשמאל, מלמעלה למטה או באלכסון)</div>

    <script>
        const words = ["שמות", "וארא", "בא", "בשלח", "יתרו", "משפטים", "תרומה", "תצוה", "כי תשא", "ויקהל", "פקודי"].map(w => w.replace(" ", ""));
        const size = 12;
        const gridElement = document.getElementById('grid');
        const ulWords = document.getElementById('ul-words');
        let grid = Array(size).fill().map(() => Array(size).fill(''));
        let isSelecting = false;
        let selectedCells = [];

        // Fill grid with words
        function fillGrid() {
            words.forEach(word => {
                let placed = false;
                while (!placed) {
                    let dir = [[0,1],[1,0],[1,1],[0,-1],[-1,0]][Math.floor(Math.random()*5)];
                    let r = Math.floor(Math.random() * size);
                    let c = Math.floor(Math.random() * size);
                    
                    if (canPlace(word, r, c, dir)) {
                        for (let i = 0; i < word.length; i++) {
                            grid[r + i*dir[0]][c + i*dir[1]] = word[i];
                        }
                        placed = true;
                    }
                }
            });

            // Fill empty with random letters
            const letters = "אבגדהוזחטיכלמנסעפצקרשת";
            for(let r=0; r<size; r++) {
                for(let c=0; c<size; c++) {
                    if(!grid[r][c]) grid[r][c] = letters[Math.floor(Math.random()*letters.length)];
                    const div = document.createElement('div');
                    div.className = 'cell';
                    div.textContent = grid[r][c];
                    div.dataset.r = r; div.dataset.c = c;
                    div.onmousedown = () => startSelect(r, c);
                    div.onmouseenter = () => updateSelect(r, c);
                    gridElement.appendChild(div);
                }
            }
        }

        function canPlace(word, r, c, dir) {
            for (let i = 0; i < word.length; i++) {
                let nr = r + i*dir[0], nc = c + i*dir[1];
                if (nr<0 || nr>=size || nc<0 || nc>=size || (grid[nr][nc] !== '' && grid[nr][nc] !== word[i])) return false;
            }
            return true;
        }

        function startSelect(r, c) { isSelecting = true; selectedCells = [[r,c]]; updateVisuals(); }
        function updateSelect(r, c) {
            if (!isSelecting) return;
            if (!selectedCells.some(cell => cell[0] === r && cell[1] === c)) {
                selectedCells.push([r,c]);
                updateVisuals();
            }
        }

        window.onmouseup = () => {
            if (!isSelecting) return;
            isSelecting = false;
            checkWord();
            selectedCells = [];
            updateVisuals();
        };

        function updateVisuals() {
            document.querySelectorAll('.cell').forEach(cell => cell.classList.remove('selected'));
            selectedCells.forEach(([r,c]) => {
                gridElement.children[r*size + c].classList.add('selected');
            });
        }

        function checkWord() {
            const selectedWord = selectedCells.map(([r,c]) => grid[r][c]).join('');
            const reversedWord = selectedWord.split('').reverse().join('');
            
            if (words.includes(selectedWord) || words.includes(reversedWord)) {
                const finalWord = words.includes(selectedWord) ? selectedWord : reversedWord;
                selectedCells.forEach(([r,c]) => gridElement.children[r*size + c].classList.add('found'));
                document.getElementById('li-' + finalWord).classList.add('found');
            }
        }

        // Initialize
        words.forEach(w => {
            const li = document.createElement('li');
            li.id = 'li-' + w;
            li.textContent = (w === "כיתשא") ? "כי תשא" : w;
            ulWords.appendChild(li);
        });
        fillGrid();

    </script>
</body>
</html>
